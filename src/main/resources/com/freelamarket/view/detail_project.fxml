<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane fitToWidth="true"
            styleClass="root"
            stylesheets="@../css/detail_project.css"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.freelamarket.controller.DetailProjectController">

    <VBox alignment="TOP_CENTER" styleClass="content-wrapper">

        <VBox spacing="25" styleClass="project-card">

            <VBox spacing="5">
                <Label fx:id="lblTitle" text="Carregando Título..." styleClass="detail-title" wrapText="true"/>
                <Label fx:id="lblClient" text="Publicado por: ..." styleClass="detail-client"/>
            </VBox>

            <HBox spacing="15" alignment="CENTER_LEFT">
                <HBox styleClass="info-badge-blue" spacing="8" alignment="CENTER_LEFT">
                    <Label text="💰" style="-fx-font-size: 16px;"/>
                    <Label fx:id="lblBudget" text="R$ 0,00" styleClass="detail-value-blue"/>
                </HBox>

                <HBox styleClass="info-badge-red" spacing="8" alignment="CENTER_LEFT">
                    <Label text="📅" style="-fx-font-size: 16px;"/>
                    <Label fx:id="lblDeadline" text="Sem prazo" styleClass="detail-value-red"/>
                </HBox>
            </HBox>

            <Separator styleClass="separator-line"/>

            <VBox spacing="10">
                <Label text="DESCRIÇÃO DETALHADA" styleClass="section-label"/>
                <Label fx:id="lblDesc"
                       text="Carregando descrição..."
                       wrapText="true"
                       styleClass="description-text"/>
            </VBox>

            <Separator styleClass="separator-line"/>

            <VBox fx:id="boxProposta" spacing="20" styleClass="propose-area">

                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label text="🚀" style="-fx-font-size: 20px;"/>
                    <Label text="ENVIAR UMA PROPOSTA" styleClass="section-label-dark"/>
                </HBox>

                <GridPane hgap="20" vgap="15">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="30"/>
                        <ColumnConstraints percentWidth="70"/>
                    </columnConstraints>

                    <VBox spacing="8" GridPane.columnIndex="0">
                        <Label text="SEU PREÇO (R$)" styleClass="input-label"/>
                        <TextField fx:id="txtValor" promptText="Ex: 1500.00" styleClass="input-field"/>
                    </VBox>

                    <VBox spacing="8" GridPane.columnIndex="1">
                        <Label text="POR QUE VOCÊ?" styleClass="input-label"/>
                        <TextArea fx:id="txtMensagem"
                                  promptText="Olá! Tenho experiência com..."
                                  prefRowCount="3"
                                  wrapText="true"
                                  styleClass="input-field"/>
                    </VBox>
                </GridPane>

                <HBox alignment="CENTER_RIGHT" spacing="15">
                    <Label fx:id="lblStatus" styleClass="msg-status" wrapText="true"/>
                    <Button text="Enviar Proposta" onAction="#sendPropose" styleClass="btn-primary"/>
                </HBox>
            </VBox>

        </VBox>
    </VBox>
</ScrollPane>