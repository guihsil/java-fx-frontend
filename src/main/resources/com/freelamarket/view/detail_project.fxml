<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="TOP_CENTER"
      styleClass="detail-container"
      stylesheets="@../css/detail_project.css"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.freelamarket.controller.DetailProjectController">

    <VBox spacing="20" maxWidth="800">

        <VBox spacing="5">
            <Label fx:id="lblTitle" styleClass="detail-title" wrapText="true"/>
            <Label fx:id="lblClient" styleClass="detail-client"/>
        </VBox>

        <VBox spacing="8">
            <Label text="Descrição Completa:" styleClass="detail-label"/>
            <TextArea fx:id="txtDesc" editable="false" wrapText="true" prefRowCount="6" styleClass="detail-textarea"/>
        </VBox>

        <Label fx:id="lblBudget" styleClass="detail-budget"/>

        <VBox fx:id="boxProposta" spacing="15" styleClass="propose-box">
            <Label text="Enviar Proposta para este Projeto" styleClass="detail-label"/>

            <TextField fx:id="txtValor" promptText="Valor Cobrado (Ex: 1500.00)" styleClass="detail-input"/>

            <TextArea fx:id="txtMensagem" promptText="Escreve aqui a tua mensagem ou argumento de venda..." prefRowCount="4" wrapText="true" styleClass="detail-textarea"/>

            <HBox alignment="CENTER_LEFT" spacing="15">
                <Button text="🚀 Enviar Proposta" onAction="#sendPropose" styleClass="btn-success"/>
                <Label fx:id="lblStatus" styleClass="msg-status" wrapText="true"/>
            </HBox>
        </VBox>

    </VBox>

</VBox>