<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane fitToWidth="true"
            styleClass="scroll-pane"
            stylesheets="@../css/profile.css"
            xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.freelamarket.controller.ProfileController">

    <VBox spacing="20" styleClass="profile-wrapper">

        <Label text="Meu Perfil" styleClass="profile-title"/>

        <VBox maxWidth="500" spacing="15" styleClass="form-card">

            <Label text="Dados Pessoais" styleClass="section-title"/>

            <TextField fx:id="nameField" promptText="Nome Completo" styleClass="profile-input"/>

            <TextField fx:id="emailField" editable="false" promptText="E-mail (Não alterável)" styleClass="profile-input-readonly"/>

            <TextField fx:id="phoneField" promptText="Telefone" styleClass="profile-input"/>

            <VBox fx:id="clientBox" spacing="10" managed="false" visible="false">
                <Label text="Dados da Empresa (Cliente)" styleClass="subtitle-client"/>
                <TextField fx:id="companyNameField" promptText="Nome da Empresa" styleClass="profile-input"/>
                <TextField fx:id="cnpjField" promptText="CNPJ" styleClass="profile-input"/>
                <TextField fx:id="addressField" promptText="Endereço" styleClass="profile-input"/>
                <TextArea fx:id="bioClientField" promptText="Bio / Sobre a Empresa" prefRowCount="3" wrapText="true" styleClass="profile-textarea"/>
            </VBox>

            <VBox fx:id="providerBox" spacing="10" managed="false" visible="false">
                <Label text="Dados Profissionais (Freelancer)" styleClass="subtitle-provider"/>
                <TextArea fx:id="bioProviderField" promptText="Sua Bio Profissional" prefRowCount="3" wrapText="true" styleClass="profile-textarea"/>
                <TextField fx:id="portfolioField" promptText="URL do Portfólio" styleClass="profile-input"/>
                <TextField fx:id="hourlyRateField" promptText="Valor Hora (Ex: 50.00)" styleClass="profile-input"/>
                <TextField fx:id="skillsField" promptText="Habilidades (Ex: Java, React, Figma)" styleClass="profile-input"/>
            </VBox>

            <HBox spacing="15" alignment="CENTER">
                <Button fx:id="btnEdit" text="Editar Perfil" onAction="#enableEdit" styleClass="btn, btn-warning"/>
                <Button fx:id="btnSave" text="Salvar Alterações" onAction="#saveEdit" styleClass="btn, btn-success" visible="false" managed="false"/>
            </HBox>

            <Label fx:id="msgLabel" styleClass="msg-error" wrapText="true"/>
        </VBox>
    </VBox>
</ScrollPane>